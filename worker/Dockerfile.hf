FROM pytorch/pytorch:2.11.0-cuda12.8-cudnn9-runtime@sha256:eee11b3b3872a8c838e35ef48f08b2d5def2080902c7f666831310ca1a0ef2be

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility \
    VIRTUAL_ENV=/opt/venv \
    PATH=/opt/venv/bin:$PATH \
    HOME=/home/worker

# Python 虚拟环境以及 OpenCV、Matplotlib 所需的系统动态库
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3-venv \
        libglib2.0-0 \
        libgl1 \
        libgomp1 \
        libsm6 \
        libxext6 \
        libxrender1 \
    && rm -rf /var/lib/apt/lists/*

# 继承基础镜像中的 PyTorch、torchvision 和 CUDA Python 包，
# 其余 Worker 依赖安装到 /opt/venv，不修改 Ubuntu 系统 Python。
RUN /usr/bin/python3 -m venv \
        --system-site-packages \
        "$VIRTUAL_ENV" \
    && python -c "import torch, torchvision; \
print('PyTorch:', torch.__version__); \
print('torchvision:', torchvision.__version__); \
print('CUDA runtime:', torch.version.cuda)"

WORKDIR /app

# 先核对固定基础镜像提供的包，再安装带 artifact SHA256 的 Worker 依赖。
COPY worker/base-packages-docker.txt \
     worker/requirements-docker.txt \
     worker/validate_base_packages.py \
     /tmp/

RUN python /tmp/validate_base_packages.py /tmp/base-packages-docker.txt \
    && python -m pip install \
        --no-cache-dir \
        --require-hashes \
        --no-deps \
        --no-build-isolation \
        -r /tmp/requirements-docker.txt

# 从固定 GitHub Release URL 下载 wheel；下载器内置且强制校验 SHA256。
COPY worker/install_detectron2_wheel.py /tmp/install_detectron2_wheel.py

RUN python /tmp/install_detectron2_wheel.py

RUN python -m pip install \
        --no-cache-dir \
        --no-deps \
        /tmp/detectron2-0.6-cp312-cp312-linux_x86_64.whl \
    && rm -f /tmp/detectron2-0.6-cp312-cp312-linux_x86_64.whl \
               /tmp/install_detectron2_wheel.py \
    && python -c "import detectron2; from detectron2 import _C; \
print('Detectron2:', detectron2.__version__); \
print('Detectron2 extension:', _C.__file__)"

# Worker、仓库内 MAMT2 runtime 和模型元数据。
COPY worker/__init__.py \
     worker/mamt2_predictor.py \
     worker/mamt2_worker_api.py \
     worker/metrics.py \
     /app/worker/
COPY worker/mamt2_runtime /app/worker/mamt2_runtime
COPY model/config.yaml \
     model/labels.json \
     model/manifest.yaml \
     model/README.md \
     /app/model/

RUN mkdir -p \
        /models \
        /outputs \
        /home/worker \
    && chown -R 1000:1000 \
        /app \
        /outputs \
        /home/worker

ENV PYTHONPATH=/app \
    MAMT2_DETECTRON2_ROOT=/opt/venv/lib/python3.12/site-packages \
    MAMT2_MAIN_DIR=/app/worker/mamt2_runtime \
    MAMT2_CONFIG_PATH=/app/model/config.yaml \
    MAMT2_WEIGHT_PATH=/models/model_best_segm.pth \
    MAMT2_OUTPUT_DIR=/outputs \
    MAMT2_WORKER_HOST=0.0.0.0 \
    MAMT2_WORKER_PORT=9000

USER 1000:1000

EXPOSE 9000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:9000/healthz', timeout=3)" || exit 1

CMD ["python", "-m", "uvicorn", "worker.mamt2_worker_api:app", \
     "--host", "0.0.0.0", "--port", "9000"]
